{
  "name": "snapeval",
  "version": "1.1.0",
  "description": "Semantic snapshot testing for AI skills. Zero assertions. AI-driven. Free inference.",
  "type": "module",
  "bin": {
    "snapeval": "./bin/snapeval.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "dev": "tsx bin/snapeval.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai-skills",
    "snapshot-testing",
    "copilot-cli",
    "agentskills",
    "evaluation",
    "semantic-testing"
  ],
  "author": "Matan Tsach",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matantsach/snapeval.git"
  },
  "homepage": "https://github.com/matantsach/snapeval",
  "bugs": {
    "url": "https://github.com/matantsach/snapeval/issues"
  },
  "files": [
    "dist/src/",
    "dist/bin/",
    "bin/",
    "src/",
    "plugin.json",
    "skills/snapeval/SKILL.md",
    "scripts/"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
