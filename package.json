{
  "name": "snapeval",
  "version": "2.3.0",
  "description": "Harness-agnostic eval runner for agentskills.io skills",
  "type": "module",
  "bin": {
    "snapeval": "./bin/snapeval.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "build": "tsc",
    "dev": "tsx bin/snapeval.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai-skills",
    "agentskills",
    "evaluation",
    "harness",
    "copilot-cli"
  ],
  "author": "Matan Tsach",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matantsach/snapeval.git"
  },
  "homepage": "https://github.com/matantsach/snapeval",
  "bugs": {
    "url": "https://github.com/matantsach/snapeval/issues"
  },
  "files": [
    "dist/src/",
    "dist/bin/",
    "bin/",
    "src/",
    "plugin.json",
    "skills/create-evals/SKILL.md",
    "skills/run-evals/SKILL.md",
    "scripts/",
    "assets/"
  ],
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
